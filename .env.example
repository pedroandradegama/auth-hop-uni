# Credenciais do portal Unimed (SEM valores reais aqui — preencher no .env real,
# que fica FORA do git e criptografado em repouso na VPS).
UNIMED_USER=
UNIMED_PASS=
EMAIL_PRESTADOR=
SETOR=receptivo

# Portal (default ja embutido no config; sobrescrever so' se mudar)
# UNIMED_PORTAL_URL=https://autorizador.unimedrecife.com.br/index_admin.php

# POLL: de onde o worker puxa o proximo job (Edge Function proximo-job-autorizacao)
HOP_PROXIMO_JOB_URL=
WORKER_INBOUND_SECRET=

# Callback: para onde o worker posta o resultado (Edge Function receive-autorizacao)
HOP_CALLBACK_URL=
HOP_CALLBACK_SECRET=

# Coleta de demonstrativos (frente 2) — worker_demonstrativo.py
# Reusa WORKER_INBOUND_SECRET (poll) e HOP_CALLBACK_SECRET (assinatura HMAC) acima.
HOP_PROXIMO_DEMONSTRATIVO_URL=
HOP_CALLBACK_DEMONSTRATIVO_URL=

# Intervalos do poll (segundos)
POLL_INTERVAL_SEG=15
POLL_INTERVAL_OCIOSO_SEG=60

# Janela da varredura (dias corridos). Default 15.
VARREDURA_JANELA_DIAS=15

# Browser
BROWSER_HEADLESS=true

# ── Sassepe (Maida Health) — adapter adapters/sassepe/ ───────────────────
# Usuario do MVOnePass e' CPF (nao email). Engine chromium (default no adapter).
SASSEPE_USER=
SASSEPE_PASS=
# SASSEPE_PORTAL_URL=https://sassepe.maida.health/sso/login
# SASSEPE_BROWSER_ENGINE=chromium

# ── Sul America Saude — adapter adapters/sulamerica/ ─────────────────────
# CODIGO = codigo do prestador; USUARIO default "master". Engine firefox.
SULAMERICA_CODIGO=
SULAMERICA_USUARIO=master
SULAMERICA_SENHA=
# SULAMERICA_PORTAL_URL=https://saude.sulamericaseguros.com.br/prestador/login/?accessError=2
# SULAMERICA_BROWSER_ENGINE=firefox

# Restringe quais convenios a varredura roda (CSV). Vazio = todos.
# CRON_CONVENIOS=unimed_recife,sassepe,sulamerica
